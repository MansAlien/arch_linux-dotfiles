# Mod key (Super/Windows)
set $mod Mod4

# Font
font pango:JetBrains Mono 11

# Terminal
set $term kitty

# App launcher
set $menu rofi -show drun -theme ~/.config/rofi/catppuccin.rasi -show-icons -icon-theme "Papirus"

# ── Autostart ─────────────────────────────────────────

exec --no-startup-id picom --config ~/.config/picom.conf -b
exec --no-startup-id nitrogen --restore
exec --no-startup-id dunst
exec --no-startup-id xss-lock -- i3lock -c 000000
exec --no-startup-id ~/.config/polybar/battery-warning.sh
exec --no-startup-id setxkbmap -layout us,ara -option grp:alt_shift_toggle
exec --no-startup-id sleep 5 && libinput-gestures

exec --no-startup-id ~/.config/polybar/launch.sh

exec --no-startup-id xinput set-prop "FTCS0038:00 2808:0106 Touchpad" "libinput Accel Speed" 0.4

# Start the Bluetooth media bridge
exec --no-startup-id /usr/lib/bluetooth/mpris-proxy

# ── Keybindings ───────────────────────────────────────
bindsym $mod+Return exec $term
bindsym $mod+p exec $menu
bindsym $mod+q kill
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec i3-msg exit

# Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Splits
bindsym $mod+b split h
bindsym $mod+v split v

# Layouts
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
floating_modifier $mod

# Bind the Media Keys (AirPods buttons)
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

# ── Workspaces ────────────────────────────────────────
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5

# ── Laptop Keys ───────────────────────────────────────
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle

bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

bindsym Print exec maim ~/Pictures/screenshot-$(date +%s).png
bindsym $mod+Print exec maim -s ~/Pictures/screenshot-$(date +%s).png

bindsym $mod+shift+x exec i3lock -c 000000
bindsym $mod+shift+s exec systemctl suspend

# ── Gaps & Borders ────────────────────────────────────
gaps inner 2
gaps outer 2
gaps top 2
default_border pixel 1
smart_borders on

include ~/.config/i3/themes/catppuccin.conf

